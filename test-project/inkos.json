{
  "name": "test-project",
  "version": "0.1.0",
  "llm": {
    "provider": "openai",
    "baseUrl": "https://api.openai.com/v1",
    "model": "gpt-5.4",
    "stream": false,
    "services": [
      {
        "service": "custom",
        "name": "KUKU",
        "baseUrl": "https://cpa.kuku.me/v1",
        "temperature": 1,
        "maxTokens": 128000,
        "apiFormat": "chat",
        "stream": true
      }
    ],
    "defaultModel": "gpt-5.4",
    "service": "custom:KUKU"
  },
  "notify": [],
  "daemon": {
    "schedule": {
      "radarCron": "0 */6 * * *",
      "writeCron": "*/15 * * * *"
    },
    "maxConcurrentBooks": 3
  },
  "language": "zh"
}